# NoteBrain CLI Environment Configuration
# Copy this file to .env and customize the values.

# The name of your Obsidian vault (used to generate obsidian://open links).
# This allows you to omit the --vault flag from your search and ingest commands.
OBSIDIAN_VAULT="Second Brain 2.0"

# Set to 1 to globally disable OSC 8 terminal hyperlinks in output.
# NO_HYPERLINKS=1
